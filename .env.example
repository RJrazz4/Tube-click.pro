# === SECURE SERVER-ONLY KEYS (NEVER prefix with VITE_) ===
# Supabase Edge: Deno.env.get() — set via `supabase secrets set`
# Vercel Edge: process.env — set in Vercel Dashboard -> Settings -> Env Vars
# OpenRouter — PRIMARY AI text provider (Phase F1). Comma-separated keys, rotated on 429/402:
OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3 (from https://openrouter.ai/keys)
# Optional overrides (defaults shown):
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_MODEL_FALLBACKS=google/gemini-2.5-flash-lite
# (2.0 IDs are retired on OpenRouter — they 400. Live-verified 2026-07-17)
# OPENROUTER_SITE_URL=https://your-deployed-domain   (optional, attribution header)
# OPENROUTER_SITE_TITLE=TubeClick.Pro                (optional, attribution header)
# AI_RETRY_BUDGET_MS=12000
# LEGACY — only used by the Supabase functions path (inactive when VITE_USE_VERCEL_EDGE=true):
GEMINI_API_KEY=your_gemini_api_key_here (from https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=alias_for_gemini_optional
FAL_API_KEY=your_fal_ai_key_here (from https://fal.ai/dashboard/keys)
ELEVENLABS_API_KEY=your_elevenlabs_key_here (from https://elevenlabs.io/app/settings/api-keys)

# Optional: Future integrations (Phase D)
POLLINATIONS_API_KEY=optional_pro_tier
SNAPGEN_API_KEY=optional_snapgen_key
JSON2VIDEO_API_KEY=optional_future_video_render

# Monetization locker (public config, safe)
LOCKER_URL=https://your-locker-url.example.com/verify
# For Vercel, also set as VITE_ public? No, use process.env LOCKER_URL and expose via /api/config (server filters)

# === PUBLIC SUPABASE CLIENT (Safe to expose — anon key only) ===
# Required for frontend to call Supabase Edge gateway
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id

# Phase 5 referral backend (server-only; never expose the service role or HMAC secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
REFERRAL_HASH_SECRET=generate_at_least_32_random_bytes
# PLG soft-gate signed preview cookie (use a separate 32+ byte random secret)
GUEST_ACCESS_SECRET=generate_another_32_random_bytes

# === API MODE — Performance Toggle ===
# false = Supabase Edge Functions (default, works now)
# true = Vercel Edge Functions /api/* (faster for US audience, <50ms cold start, edge caching)
VITE_USE_VERCEL_EDGE=false
VITE_API_MODE=supabase

# === App Config ===
VITE_APP_ENV=production
VITE_APP_URL=https://tubegenius.pro
VITE_APP_NAME=TubeGenius Pro

# Phase 5 native sponsorship inventory (public display copy; no secrets)
# Banner remains hidden unless every field is configured and the placement is enabled.
# VITE_SPONSOR_PLACEMENTS=seo,voice
# VITE_SPONSOR_ALLOWED_HOSTS=partner.example.com
# VITE_SPONSOR_NAME=Partner Name
# VITE_SPONSOR_TAGLINE=Premium creator offer
# VITE_SPONSOR_OFFER=Exclusive benefit for TubeClick creators
# VITE_SPONSOR_CTA_TEXT=Claim Partner Perk
# VITE_SPONSOR_CTA_URL=https://partner.example.com/tubeclick
# VITE_SPONSOR_BADGE=Featured Partner

# === Intelligent Orchestrator — SERVER-ONLY (Phase A1+) ===
# Validated fail-fast at boot by packages/shared/env — never prefix with VITE_.
#
# Pooled image-provider keys in ONE var: "<provider>:<k1,k2>;<provider2>:<k3>"
#   providers: agnes | gemini | hf   (aliases: agnes-flash, gemini-flash, huggingface)
#   order within a pool = rotation order (Phase A2 KeyPool)
# IMAGE_API_KEYS=agnes:ak_1,ak_2;gemini:gk_1;hf:hf_1
#
# Manager brain (OpenRouter) — pooled plural preferred; legacy singular also accepted:
# OPENROUTER_API_KEY=sk-or-v1-single-fallback
# Manager model override — default pinned in code: xiaomi/mimo-v2-flash:free
# (plan's "xiaomi/mimo-v2.5-free" does not exist in OpenRouter's registry; verified 2026-07-18)
# OPENROUTER_MODEL=xiaomi/mimo-v2-flash:free
#
# Ultimate free fallback (needs no key):
# POLLINATIONS_ENABLED=true
#
# Business-tier limits as JSON, deep-merged onto defaults ("maxScenes":null = unlimited):
# TIER_LIMITS={"free":{"maxScenes":4,"thumbnailOptions":[1,2]},"pro":{"maxScenes":8,"thumbnailOptions":[1,2,4]},"cinematic":{"maxScenes":null,"thumbnailOptions":[1,2,4]}}
