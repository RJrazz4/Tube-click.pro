# === SECURE SERVER-ONLY KEYS (NEVER prefix with VITE_) ===
# Supabase Edge: Deno.env.get() — set via `supabase secrets set`
# Vercel Edge: process.env — set in Vercel Dashboard -> Settings -> Env Vars
GEMINI_API_KEY=your_gemini_api_key_here (from https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=alias_for_gemini_optional
FAL_API_KEY=your_fal_ai_key_here (from https://fal.ai/dashboard/keys)
ELEVENLABS_API_KEY=your_elevenlabs_key_here (from https://elevenlabs.io/app/settings/api-keys)

# Optional: Future integrations (Phase D)
POLLINATIONS_API_KEY=optional_pro_tier
SNAPGEN_API_KEY=optional_snapgen_key
JSON2VIDEO_API_KEY=optional_future_video_render

# Monetization locker (public config, safe)
LOCKER_URL=https://your-locker-url.example.com/verify
# For Vercel, also set as VITE_ public? No, use process.env LOCKER_URL and expose via /api/config (server filters)

# === PUBLIC SUPABASE CLIENT (Safe to expose — anon key only) ===
# Required for frontend to call Supabase Edge gateway
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id

# === API MODE — Performance Toggle ===
# false = Supabase Edge Functions (default, works now)
# true = Vercel Edge Functions /api/* (faster for US audience, <50ms cold start, edge caching)
VITE_USE_VERCEL_EDGE=false
VITE_API_MODE=supabase

# === App Config ===
VITE_APP_ENV=production
VITE_APP_URL=https://tubegenius.pro
VITE_APP_NAME=TubeGenius Pro
