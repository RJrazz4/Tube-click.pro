# === SECURE SERVER-ONLY KEYS (NEVER prefix with VITE_) ===
# Supabase Edge Functions + Vercel Edge will read these via Deno.env / process.env
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_key_alias
FAL_API_KEY=your_fal_ai_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: Future integrations
POLLINATIONS_API_KEY=optional_if_you_use_pro
SNAPGEN_API_KEY=optional_snapgen_key
JSON2VIDEO_API_KEY=optional_future_video_render

# Monetization locker (server can inject into frontend via safe config)
LOCKER_URL=https://your-locker-url.example.com/verify

# === PUBLIC SUPABASE CLIENT (Safe to expose — anon key only) ===
# These are required for frontend Supabase client to call edge functions
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id

# === App Config ===
VITE_APP_ENV=production
VITE_APP_URL=https://tubegenius.pro
